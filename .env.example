# Copy this file to .env and fill in your values
# Never commit .env to version control

# OpenAI API key (used by baseline.py)
OPENAI_API_KEY=sk-...

# Server config
SOC_ENV_HOST=0.0.0.0
SOC_ENV_PORT=8000

# Enable the Gradio web debug UI (set to true for local development)
ENABLE_WEB_INTERFACE=false

# HuggingFace token (for deployment)
HF_TOKEN=hf_...
